                  <div className="absolute right-0 top-1/2 -translate-y-1/2 flex flex-col gap-0.5">
                    <button onClick={() => handleReorder(server.id, "up")} className="flex items-center justify-center w-5 h-4 rounded text-textMuted hover:text-primary hover:bg-primaryLight text-[10px]" aria-label="انتقال به بالا">
                      <ChevronUp className="w-3 h-3" />
