/* === Dense operations layout for high-volume Jobs and Linked Servers === */
.compact-pane-header {
  align-items: center;
  padding: 12px 14px;
  margin-bottom: 10px;
}
.compact-pane-header h2 { margin: 0; }
.pane-subtitle {
  margin-top: 4px;
  color: var(--faint);
  font-size: 12px;
  line-height: 1.6;
}
.ops-count {
  border: 1px solid rgba(55, 189, 248, .22);
  color: #a7f3d0;
  background: rgba(45, 212, 191, .08);
  border-radius: 999px;
  padding: 7px 10px;
  font-size: 12px;
  font-weight: 900;
  white-space: nowrap;
}
.ops-toolbar {
  display: grid;
  grid-template-columns: minmax(260px, 1fr) 210px;
  gap: 10px;
  margin-bottom: 10px;
  padding: 10px;
  border: 1px solid rgba(148, 163, 184, .14);
  border-radius: 18px;
  background: rgba(2, 6, 23, .26);
}
.ops-toolbar .neo-input,
.ops-toolbar .neo-select { min-height: 38px; border-radius: 12px; }
.ops-table-wrap {
  max-height: calc(100vh - 310px);
  min-height: 270px;
  border-radius: 18px;
}
.compact-ops-table {
  min-width: 980px;
  table-layout: fixed;
}
.compact-ops-table th,
.compact-ops-table td {
  padding: 8px 10px;
  vertical-align: middle;
  font-size: 12.5px;
  line-height: 1.45;
}
.compact-ops-table th {
  height: 38px;
  letter-spacing: 0;
}
.compact-ops-table tr { min-height: 48px; }
.compact-ops-table tbody tr:hover td { background: rgba(56, 189, 248, .055); }
.nowrap { white-space: nowrap; }
.ltr-line { direction: ltr; text-align: right; }
.jobs-table th:nth-child(1), .jobs-table td:nth-child(1) { width: 28%; }
.jobs-table th:nth-child(2), .jobs-table td:nth-child(2) { width: 105px; }
.jobs-table th:nth-child(3), .jobs-table td:nth-child(3) { width: 170px; }
.jobs-table th:nth-child(4), .jobs-table td:nth-child(4) { width: 150px; }
.jobs-table th:nth-child(5), .jobs-table td:nth-child(5) { width: 82px; }
.jobs-table th:nth-child(6), .jobs-table td:nth-child(6) { width: 145px; }
.jobs-table th:nth-child(7), .jobs-table td:nth-child(7) { width: 210px; }
.job-name-cell strong,
.linked-name-cell strong {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #e5eefc;
}
.job-name-cell span {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--faint);
  margin-top: 3px;
  font-size: 11.5px;
}
.job-run-cell small,
.linked-meta-cell small {
  display: block;
  color: var(--faint);
  margin-top: 3px;
  direction: ltr;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.status-dot-text {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-weight: 900;
  white-space: nowrap;
}
.status-dot-text::before {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #94a3b8;
  box-shadow: 0 0 0 4px rgba(148, 163, 184, .08);
}
.dot-ok::before { background: var(--success); box-shadow: 0 0 0 4px rgba(45, 212, 191, .11); }
.dot-fail::before { background: var(--danger); box-shadow: 0 0 0 4px rgba(251, 113, 133, .12); }
.dot-muted::before { background: #94a3b8; }
.job-category-cell {
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.compact-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6px;
  flex-wrap: nowrap;
}
.icon-action {
  width: 31px;
  height: 31px;
  border-radius: 10px;
  border: 1px solid rgba(148, 163, 184, .18);
  background: rgba(15, 23, 42, .8);
