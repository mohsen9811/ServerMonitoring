}
.icon-action:hover { border-color: rgba(56, 189, 248, .45); color: var(--brand); transform: translateY(-1px); }
.icon-action:disabled,
.btn-action:disabled,
.primary-btn:disabled { opacity: .42; cursor: not-allowed; transform: none; }
.compact-manage {
  min-height: 31px;
  padding: 6px 9px;
  border-radius: 10px;
  font-size: 12px;
  white-space: nowrap;
}
.row-warning td { background: rgba(245, 158, 11, .035); }

.ops-linked-list,
.conn-list.ops-linked-list {
  display: block;
}
.linked-table-wrap { max-height: calc(100vh - 310px); }
.linked-table { min-width: 1020px; }
.linked-table th:nth-child(1), .linked-table td:nth-child(1) { width: 21%; }
.linked-table th:nth-child(2), .linked-table td:nth-child(2) { width: 105px; }
.linked-table th:nth-child(3), .linked-table td:nth-child(3) { width: 24%; }
.linked-table th:nth-child(4), .linked-table td:nth-child(4) { width: 170px; }
.linked-table th:nth-child(5), .linked-table td:nth-child(5) { width: 25%; }
.linked-table th:nth-child(6), .linked-table td:nth-child(6) { width: 90px; }
.linked-meta-cell span {
  display: block;
  color: #cbd5e1;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.linked-tests-cell {
  display: flex;
  gap: 5px;
  align-items: center;
  flex-wrap: wrap;
}
.linked-tests-cell .mini-status {
  min-height: 23px;
  padding: 3px 7px;
  font-size: 11px;
}
.linked-message-cell strong {
  display: block;
  color: var(--muted);
  font-size: 12px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.linked-message-cell details { margin-top: 4px; }
.linked-message-cell summary {
  cursor: pointer;
  color: var(--brand);
  font-size: 11.5px;
  font-weight: 900;
}
.linked-message-cell pre {
  max-height: 150px;
  overflow: auto;
  margin-top: 6px;
  padding: 8px;
  font-size: 11px;
}
.linked-row.testing td {
  background: rgba(56, 189, 248, .06) !important;
}

@media (max-width: 760px) {
  .ops-toolbar { grid-template-columns: 1fr; }
  .compact-pane-header { align-items: stretch; }
  .compact-actions { justify-content: flex-start; }
}

/* Live / operational additions */
