import { useState, useEffect } from "react";
import { useServerStore } from "../../stores/serverStore";
import {
  Plus, GripVertical, Search, ChevronUp, ChevronDown,
  Database, Globe, CreditCard, LayoutDashboard
} from "lucide-react";
import { Button } from "../ui/Button";
import { cn } from "../../lib/utils";

interface SidebarProps {
  collapsed: boolean;
  onToggle: () => void;
}

export function Sidebar({ collapsed, onToggle }: SidebarProps) {
  const { servers, currentServerId, setCurrentServer, setSearchQuery, sortMode, toggleSortMode, addServer, reorderServers } = useServerStore();
  const [localSearch, setLocalSearch] = useState("");

  useEffect(() => {
    const t = setTimeout(() => setSearchQuery(localSearch), 300);
    return () => clearTimeout(t);
  }, [localSearch]);

  const filteredServers = servers.filter((s) => {
    if (!localSearch) return true;
    const q = localSearch.toLowerCase();
    return s.name.toLowerCase().includes(q) || s.host.toLowerCase().includes(q);
  });

  const handleReorder = (id: string, direction: "up" | "down") => {
    const idx = servers.findIndex((s) => s.id === id);
    if (idx === -1) return;
    const newServers = [...servers];
    const target = direction === "up" ? idx - 1 : idx + 1;
    if (target < 0 || target >= newServers.length) return;
    [newServers[idx], newServers[target]] = [newServers[target], newServers[idx]];
    // We'd call reorder API, but for now just update store
    reorderServers(newServers.map((s) => s.id));
  };

  return (
    <>
      {/* Brand */}
      <div className={cn("flex items-center gap-3 px-4 py-4 border-b border-border/60", collapsed ? "justify-center" : "")}>
        {!collapsed && (
          <>
            <div className="w-10 h-10 rounded-2xl premium-gradient flex items-center justify-center text-white font-black shadow-glow shrink-0">
              <LayoutDashboard className="w-5 h-5" />
            </div>
            <div className="min-w-0">
              <div className="font-extrabold text-textMain truncate">Server Pulse</div>
              <div className="text-[11px] text-textMuted font-medium">Operations Panel</div>
            </div>
          </>
        )}
        <button
          onClick={onToggle}
          className="flex items-center justify-center w-8 h-8 rounded-xl text-textMuted hover:bg-primaryLight hover:text-primary transition-all duration-200 shrink-0"
          aria-label={collapsed ? "باز کردن سایدبار" : "بستن سایدبار"}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" className="transition-transform" style={{ transform: collapsed ? "rotate(180deg)" : "" }}>
