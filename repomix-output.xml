.server-title-text { min-width: 0; }
.eyebrow { display: block; color: var(--muted); font-size: 12px; margin-bottom: 3px; letter-spacing: .2px; }
.server-title h1 { font-size: 23px; line-height: 1.25; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.server-host-line { color: var(--faint); font-size: 12px; direction: ltr; display: block; margin-top: 2px; text-align: right; }
.server-feature-badge { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 8px 11px; font-weight: 800; font-size: 12px; white-space: nowrap; }
.server-feature-badge.enabled { color: #99f6e4; background: rgba(45,212,191,.12); border: 1px solid rgba(45,212,191,.28); }
.server-feature-badge.disabled { color: #bfdbfe; background: rgba(96,165,250,.11); border: 1px solid rgba(96,165,250,.28); }
.header-actions { display: flex; gap: 10px; align-items: center; }
.icon-btn { width: 42px; height: 42px; border: 1px solid var(--line); background: #0d1728; color: var(--text); border-radius: 14px; display: grid; place-items: center; position: relative; }
.icon-btn:hover { border-color: rgba(55,189,248,.55); color: var(--brand); }
.alert-icon-btn span { position: absolute; top: -5px; left: -5px; min-width: 20px; height: 20px; padding: 0 5px; border-radius: 999px; background: var(--danger); color: white; font-size: 11px; display: grid; place-items: center; }

.tab-bar {
  display: flex;
  gap: 7px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--line);
  background: rgba(5, 12, 23, .48);
  overflow-x: auto;
  overflow-y: hidden;
}
.tab-btn {
  flex: 0 0 auto;
  min-width: 94px;
  height: 39px;
  padding: 0 13px;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: rgba(2,6,23,.34);
  color: var(--muted);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-weight: 800;
  white-space: nowrap;
  transition: .16s ease;
  font-size: 13px;
}
.tab-btn:hover { border-color: var(--line-2); color: var(--text); background: #111f34; }
.tab-btn.active { color: #04111d; border-color: transparent; background: linear-gradient(135deg, #67e8f9, #a7f3d0); box-shadow: 0 10px 22px rgba(34,211,238,.18); }
.tab-btn.is-hidden, .server-no-sql .sql-only, .server-no-iis .iis-only, .tab-btn.is-hidden { display: none !important; }

.stats-ribbon { display: grid; grid-template-columns: repeat(5, minmax(0,1fr)); gap: 10px; padding: 14px 18px 0; }
.stat-item {
  min-height: 74px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px;
  border-radius: 18px;
  border: 1px solid var(--line);
  background: linear-gradient(180deg, rgba(255,255,255,.045), rgba(255,255,255,.018));
}
.stat-item > i { width: 40px; height: 40px; border-radius: 13px; color: var(--brand); display: grid; place-items: center; background: rgba(55,189,248,.1); }
.stat-item span { display: block; font-size: 22px; font-weight: 900; direction: ltr; text-align: right; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.stat-item small { color: var(--muted); }
.stat-clickable { cursor: pointer; }
.stat-clickable:hover { border-color: rgba(251,113,133,.48); }

.tab-content-container { flex: 1; min-height: 0; overflow: auto; padding: 18px; }
.tab-pane { display: none; animation: fadeIn .16s ease; }
.tab-pane.active { display: block; }
@keyframes fadeIn { from { opacity: .6; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }

.dashboard-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 22px;
  border-radius: 22px;
  border: 1px solid rgba(55,189,248,.22);
  background:
    radial-gradient(circle at 10% 20%, rgba(55,189,248,.18), transparent 38%),
    linear-gradient(135deg, rgba(17,30,51,.92), rgba(15,23,42,.76));
  box-shadow: var(--shadow-sm);
}
.dashboard-hero h2 { font-size: 26px; margin-bottom: 6px; }
.dashboard-hero p { color: var(--muted); }
.hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
.ops-status-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 12px; margin: 14px 0; }
.ops-status-card {
  position: relative;
  min-height: 118px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(15,23,42,.84), rgba(15,23,42,.54));
  color: var(--text);
  text-align: right;
  padding: 16px;
  display: grid;
  gap: 6px;
  align-content: start;
  transition: .16s ease;
  overflow: hidden;
}
.ops-status-card::after { content: ""; position: absolute; inset: auto 0 0 0; height: 3px; background: var(--line-2); }
.ops-status-card:hover, .overview-card:hover { transform: translateY(-2px); border-color: rgba(55,189,248,.45); background: var(--card-hover); }
.ops-status-card.is-ok::after { background: var(--success); } .ops-status-card.is-warning::after { background: var(--warning); } .ops-status-card.is-danger::after { background: var(--danger); }
.ops-icon { width: 42px; height: 42px; border-radius: 14px; background: rgba(34,211,238,.12); color: #67e8f9; border: 1px solid rgba(34,211,238,.24); display: grid; place-items: center; margin-bottom: 4px; }
.ops-status-card small { color: var(--muted); font-weight: 800; }
.ops-status-card strong { font-size: 20px; }
.ops-status-card em { color: var(--faint); font-style: normal; line-height: 1.7; }
.dashboard-layout-grid { display: grid; grid-template-columns: minmax(0,1.4fr) minmax(310px,.8fr); gap: 14px; }
.dashboard-panel, .pane-card, .settings-section-card, .server-form-section {
  border: 1px solid var(--line);
  border-radius: 18px;
  background: linear-gradient(180deg, rgba(15,23,42,.84), rgba(15,23,42,.54));
  box-shadow: var(--shadow-sm);
}
.dashboard-panel { padding: 16px; }
.panel-title { display: flex; align-items: center; justify-content: space-between; gap: 10px; margin-bottom: 14px; font-weight: 900; }
.panel-title > span { margin-inline-end: auto; }
.dashboard-overview-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 10px; }
.overview-card {
  min-height: 90px;
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 14px;
  background: #0d1728;
  color: var(--text);
  text-align: right;
  display: grid;
  grid-template-columns: 38px 1fr;
  grid-template-areas: "icon title" "icon sub";
  column-gap: 12px;
  align-content: center;
  transition: .16s ease;
}
.overview-card i { grid-area: icon; width: 38px; height: 38px; border-radius: 12px; background: rgba(55,189,248,.1); color: var(--brand); display: grid; place-items: center; }
.overview-card strong { grid-area: title; font-size: 15px; }
.overview-card span { grid-area: sub; color: var(--muted); margin-top: 4px; }
.dashboard-alert-preview { display: grid; gap: 10px; }
.preview-empty { min-height: 190px; display: grid; place-items: center; align-content: center; gap: 8px; color: var(--muted); text-align: center; border: 1px dashed var(--line); border-radius: 16px; }
.preview-empty i { color: var(--success); font-size: 28px; }
.preview-empty strong { color: var(--text); font-size: 18px; }
.preview-alert { width: 100%; border: 1px solid var(--line); border-right: 4px solid var(--warning); border-radius: 15px; padding: 12px; color: var(--text); background: #0d1728; text-align: right; display: grid; gap: 4px; }
.preview-alert.critical { border-right-color: var(--danger); }
.preview-alert span { color: var(--warning); font-size: 12px; font-weight: 900; }
.preview-alert.critical span { color: var(--danger); }
.preview-alert em { color: var(--muted); font-style: normal; }

.pane-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 12px;
  padding: 14px 16px;
  border-radius: 18px;
  border: 1px solid var(--line);
  background: linear-gradient(180deg, rgba(15,23,42,.84), rgba(15,23,42,.54));
  box-shadow: var(--shadow-sm);
}
.pane-header h2 { font-size: 18px; display: flex; align-items: center; gap: 9px; }
.pane-tools, .pane-header > div { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
.primary-btn, .action-btn, .danger-btn, .btn-action, .link-btn {
  border-radius: 12px;
  padding: 10px 13px;
  min-height: 38px;
  border: 1px solid var(--line);
  background: #0d1728;
  color: var(--text);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  transition: .16s ease;
  text-decoration: none;
}
.primary-btn { border-color: transparent; background: linear-gradient(135deg, #22d3ee, #34d399); color: #031018; font-weight: 900; }
.small-primary { min-height: 34px; padding: 8px 11px; font-size: 13px; }
.action-btn:hover, .btn-action:hover, .link-btn:hover { border-color: rgba(55,189,248,.45); color: var(--brand); }
.primary-btn:hover { filter: brightness(1.06); transform: translateY(-1px); }
.danger-btn { background: rgba(251,113,133,.12); border-color: rgba(251,113,133,.32); color: #fecdd3; }
.full-width { width: 100%; }
.link-btn { min-height: 30px; padding: 6px 10px; background: transparent; color: var(--brand); }

.table-wrap { overflow: auto; border-radius: 16px; border: 1px solid var(--line); background: rgba(2,6,23,.20); }
.data-table { width: 100%; border-collapse: collapse; min-width: 850px; }
.data-table th, .data-table td { padding: 13px 12px; border-bottom: 1px solid rgba(148,163,184,.09); text-align: right; vertical-align: top; }
.data-table th { position: sticky; top: 0; z-index: 2; background: rgba(2,6,23,.46); color: #c8d5e6; font-size: 12px; white-space: nowrap; }
.data-table tr:hover td { background: rgba(55,189,248,.035); }
.compact-table th, .compact-table td { padding: 9px 10px; font-size: 13px; }
.table-actions, .job-actions-cell { display: flex; gap: 6px; flex-wrap: wrap; }
.loading, .error-cell { padding: 18px; color: var(--muted); text-align: center; }
.error-cell { color: #fecdd3; }
.muted-line { color: var(--faint); font-size: 12px; margin-top: 4px; }
.path-cell { direction: ltr; text-align: left !important; max-width: 420px; white-space: normal; word-break: break-all; }
.row-danger td { background: rgba(251,113,133,.06); }
.target-highlight { outline: 2px solid var(--brand); box-shadow: 0 0 0 5px rgba(55,189,248,.14); }

.status-badge, .mini-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 26px;
  padding: 4px 9px;
  border-radius: 999px;
  font-size: 12px;
  font-weight: 900;
  border: 1px solid transparent;
  white-space: nowrap;
}
.status-running, .mini-ok { background: rgba(45,212,191,.12); color: #99f6e4; border-color: rgba(45,212,191,.28); }
.status-stopped, .mini-fail { background: rgba(251,113,133,.12); color: #fecdd3; border-color: rgba(251,113,133,.28); }
.status-warning, .mini-skip { background: rgba(245,158,11,.12); color: #fde68a; border-color: rgba(245,158,11,.28); }
.status-notfound { background: rgba(148,163,184,.12); color: #cbd5e1; border-color: rgba(148,163,184,.24); }
.btn-start { color: #99f6e4; } .btn-stop, .btn-remove, .btn-stop-force { color: #fecdd3; } .btn-restart, .btn-restart-force { color: #bfdbfe; }

.service-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px,1fr)); gap: 12px; }
.service-card, .disk-card, .conn-card, .alert-card {
  border: 1px solid var(--line);
  border-radius: 18px;
  background: rgba(17,30,51,.78);
  padding: 16px;
  box-shadow: var(--shadow-sm);
}
.svc-name { display: flex; align-items: center; gap: 8px; font-weight: 900; margin-bottom: 6px; }
.svc-display, .disk-volume, .conn-meta, .conn-message { color: var(--muted); line-height: 1.8; }
.svc-actions { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 13px; }

.disk-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px,1fr)); gap: 12px; }
.drive-letter { display: flex; align-items: center; gap: 8px; font-size: 18px; font-weight: 900; margin-bottom: 7px; }
.disk-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin: 13px 0; color: var(--muted); font-size: 13px; }
.disk-bar-bg, .progress-bar { height: 10px; border-radius: 999px; background: #07111f; overflow: hidden; border: 1px solid var(--line); }
.disk-bar-fill, .progress-fill { height: 100%; border-radius: 999px; background: var(--success); transition: width .25s ease; }
.disk-bar-fill.medium { background: var(--warning); } .disk-bar-fill.high { background: var(--danger); }
.disk-warning { border-color: rgba(245,158,11,.4); } .disk-critical { border-color: rgba(251,113,133,.48); }

.file-search-bar { display: grid; grid-template-columns: minmax(0,1fr) auto; gap: 10px; margin-bottom: 14px; }
.neo-input, .neo-select, textarea.neo-input {
  width: 100%;
  border: 1px solid var(--line);
  background: #081323;
  color: var(--text);
  border-radius: 13px;
  min-height: 42px;
  padding: 10px 12px;
  outline: none;
}
.neo-input:focus, .neo-select:focus { border-color: var(--brand); box-shadow: 0 0 0 4px rgba(55,189,248,.12); }
.input-group { display: grid; gap: 7px; }
.input-group label { color: var(--muted); font-weight: 800; font-size: 12px; }

.conn-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px,1fr)); gap: 12px; }
.conn-card { display: grid; gap: 12px; position: relative; overflow: hidden; }
.conn-card.connected { border-color: rgba(45,212,191,.4); } .conn-card.failed { border-color: rgba(251,113,133,.48); } .conn-card.warning { border-color: rgba(245,158,11,.45); }
.conn-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
.conn-title h3 { font-size: 17px; margin-bottom: 5px; direction: ltr; text-align: right; }
.conn-provider, .conn-details, .conn-tests { display: flex; flex-wrap: wrap; gap: 7px; color: var(--muted); }
.conn-actions { display: flex; justify-content: flex-end; }
.conn-message details { margin-top: 8px; }
pre { white-space: pre-wrap; word-break: break-word; direction: ltr; text-align: left; background: #06101d; padding: 10px; border-radius: 12px; border: 1px solid var(--line); color: #dbeafe; }

.system-metrics { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 12px; }
.metric-panel { display: grid; grid-template-columns: 52px 1fr; gap: 14px; border: 1px solid var(--line); border-radius: 18px; background: rgba(17,30,51,.78); padding: 17px; }
.metric-icon { width: 52px; height: 52px; border-radius: 16px; display: grid; place-items: center; background: rgba(55,189,248,.1); color: var(--brand); }
.metric-info h4 { color: var(--muted); margin-bottom: 6px; }
.metric-value { font-size: 28px; font-weight: 900; margin-bottom: 9px; direction: ltr; text-align: right; }
.ram-detail, .uptime-detail { color: var(--faint); margin-top: 8px; }
.auto-refresh-label { display: flex; align-items: center; gap: 7px; color: var(--muted); }

.alerts-summary { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 10px; margin-bottom: 12px; }
.alert-counter { border: 1px solid var(--line); border-radius: 16px; background: rgba(17,30,51,.78); padding: 14px; display: flex; align-items: center; justify-content: space-between; }
.alert-counter strong { font-size: 26px; } .alert-counter.critical strong { color: var(--danger); } .alert-counter.warning strong { color: var(--warning); }
.alerts-list { display: grid; gap: 10px; }
.alert-card { border-right: 4px solid var(--warning); }
.alert-card.alert-critical { border-right-color: var(--danger); }
.alert-head, .alert-foot { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; color: var(--muted); }
.alert-card h3 { margin: 10px 0 6px; }
.alert-card p { color: var(--muted); line-height: 1.9; }
.alert-foot { margin-top: 12px; }
.alert-severity { font-weight: 900; color: var(--warning); } .alert-critical .alert-severity { color: var(--danger); }
.empty-alerts { min-height: 180px; display: grid; place-items: center; gap: 8px; color: var(--muted); border: 1px dashed var(--line); border-radius: 18px; }

.settings-form, .server-modal-body { display: grid; gap: 14px; }
.settings-grid, .credential-grid, .basic-fields { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 12px; }
.server-form-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 12px; }
.basic-section { grid-column: 1 / -1; }
.server-form-section, .settings-section-card { padding: 15px; }
.section-title, .settings-section-card h3 { display: flex; align-items: center; gap: 8px; font-weight: 900; margin-bottom: 12px; }
.switch-row { display: flex; align-items: center; gap: 10px; padding: 12px; border-radius: 14px; background: rgba(55,189,248,.06); border: 1px solid var(--line); margin-bottom: 12px; }
.switch-row input { width: 18px; height: 18px; accent-color: var(--brand); }
.warning-note, .info-note, .feature-disabled-card { border: 1px solid rgba(245,158,11,.28); border-radius: 16px; background: rgba(245,158,11,.08); color: #fde68a; padding: 13px; line-height: 1.8; }
.info-note { border-color: rgba(96,165,250,.28); background: rgba(96,165,250,.08); color: #bfdbfe; }
.feature-disabled-card { display: grid; place-items: center; text-align: center; color: var(--muted); background: rgba(96,165,250,.07); border-color: rgba(96,165,250,.22); min-height: 170px; }
.feature-disabled-card.compact { min-height: auto; margin-top: 14px; display: flex; gap: 12px; text-align: right; align-items: center; justify-content: flex-start; }
.feature-disabled-card h3 { color: var(--text); margin-bottom: 6px; }
.modal-actions { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 10px; }

.glass-modal { display: none; position: fixed; inset: 0; z-index: 50; align-items: center; justify-content: center; padding: 18px; background: rgba(2, 6, 23, .72); backdrop-filter: blur(12px); }
.modal-window { width: min(760px, 96vw); max-height: 90vh; overflow: hidden; display: flex; flex-direction: column; border: 1px solid var(--line); border-radius: 22px; background: linear-gradient(180deg, #0f172a, #07111f); box-shadow: var(--shadow); }
.server-modal-window { width: min(980px, 96vw); }
.job-manager-window, .database-details-window { width: min(1180px, 96vw); }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 18px; border-bottom: 1px solid var(--line); background: #111e33; font-weight: 900; }
.modal-close { width: 34px; height: 34px; border-radius: 11px; display: grid; place-items: center; color: var(--muted); cursor: pointer; }
.modal-close:hover { background: rgba(251,113,133,.12); color: #fecdd3; }
.modal-body { padding: 16px; overflow: auto; }
.search-results { display: grid; gap: 8px; margin-top: 12px; }
.search-result-item { display: flex; justify-content: space-between; gap: 10px; align-items: center; border: 1px solid var(--line); border-radius: 14px; padding: 10px; background: #0b1728; }
.service-item {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  align-items: center;
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 10px;
  background: rgba(2,6,23,.42);
  cursor: pointer;
  transition: .16s ease;
}
.service-item:hover { border-color: rgba(34,211,238,.45); background: rgba(34,211,238,.08); transform: translateY(-1px); }
.service-name { font-weight: 900; color: var(--text); }
.service-display { color: var(--muted); font-size: 12px; }

.details-grid, .db-summary-grid, .manager-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px,1fr)); gap: 10px; margin-bottom: 14px; }
.mini-card { border: 1px solid var(--line); border-radius: 15px; background: #0b1728; padding: 13px; display: grid; gap: 5px; }
.mini-card small { color: var(--muted); } .mini-card strong { font-size: 16px; }
.manager-actions { display: flex; gap: 8px; flex-wrap: wrap; margin: 12px 0; }
.modal-section { margin-top: 18px; }
.modal-section h3 { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
.history-table-wrap { max-height: 300px; }
.history-message { max-width: 520px; white-space: normal; line-height: 1.7; }
.job-step-command { max-height: 240px; overflow: auto; }
.kv-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px,1fr)); gap: 10px; }
.kv-grid > div { border: 1px solid var(--line); border-radius: 12px; background: #0b1728; padding: 10px; color: var(--muted); }
.kv-grid b { color: var(--text); }

.toast-message { position: fixed; z-index: 70; bottom: 18px; left: 18px; max-width: min(520px, calc(100vw - 36px)); padding: 13px 16px; border-radius: 15px; border: 1px solid var(--line); background: #111e33; color: var(--text); box-shadow: var(--shadow); white-space: pre-wrap; transition: opacity .3s ease, transform .3s ease; }
.toast-message.success { border-color: rgba(45,212,191,.38); } .toast-message.error { border-color: rgba(251,113,133,.45); } .toast-message.warning { border-color: rgba(245,158,11,.45); }
.hidden { display: none !important; }
.global-loader { position: fixed; z-index: 65; inset: 0; display: grid; place-items: center; align-content: center; gap: 12px; background: rgba(2,8,18,.48); backdrop-filter: blur(4px); animation: fadeIn .2s ease; }
.loader { width: 42px; height: 42px; border-radius: 999px; border: 4px solid rgba(255,255,255,.16); border-top-color: var(--brand); animation: spin .8s linear infinite; box-shadow: 0 0 20px rgba(34,211,238,.15); }

@media (max-width: 1220px) {
  .horizon-dashboard { grid-template-columns: 260px minmax(0,1fr); }
  .tab-bar { gap: 5px; }
  .tab-btn { min-width: 72px; font-size: 12px; padding: 0 10px; }
  .tab-btn span { display: none; }
  .ops-status-grid, .stats-ribbon { grid-template-columns: repeat(2, minmax(0,1fr)); }
  .dashboard-layout-grid { grid-template-columns: 1fr; }
