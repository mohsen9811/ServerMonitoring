<file path="frontend-new/src/components/tabs/DashboardTab.tsx">
import { Card, CardContent } from "../ui/Card";
import { Badge } from "../ui/Badge";
import { Button } from "../ui/Button";
import { UsageAreaChart } from "../charts/index";
import {
  RefreshCw, Cpu, HardDrive, Wrench, Database, Bell, Server,
  Activity, AlertTriangle, CheckCircle
} from "lucide-react";
import { useSystemMetrics, useDiskInfo, useServices, useDatabases, useAlerts } from "../../hooks/useQueries";
import { formatPercent, formatRelativeTime } from "../../lib/utils";

interface DashboardTabProps {
  serverId: string | null;
}

export function DashboardTab({ serverId }: DashboardTabProps) {
  if (!serverId) return null;

  const { data: system, isLoading: sysLoading } = useSystemMetrics(serverId);
  const { data: disks, isLoading: diskLoading } = useDiskInfo(serverId);
  const { data: services, isLoading: svcLoading } = useServices(serverId);
  const { data: databases, isLoading: dbLoading } = useDatabases(serverId);
  const { data: alerts } = useAlerts(serverId);

  const cpuPercent = system?.cpuPercent ?? 0;
  const ramPercent = system?.ramPercent ?? 0;
  const worst = Math.max(cpuPercent, ramPercent);

  // Simulated time-series data for the chart (5 data points from current values)
  const chartData = [
    { time: "۲۰:۴۵", cpu: Math.max(0, cpuPercent - 5), ram: Math.max(0, ramPercent - 3) },
    { time: "۲۰:۵۰", cpu: Math.max(0, cpuPercent - 2), ram: Math.max(0, ramPercent - 1) },
    { time: "۲۰:۵۵", cpu: cpuPercent, ram: ramPercent },
    { time: "۲۱:۰۰", cpu: Math.min(100, cpuPercent + 3), ram: Math.min(100, ramPercent + 2) },
    { time: "۲۱:۰۵", cpu: Math.min(100, cpuPercent + 1), ram: Math.min(100, ramPercent + 1) },
  ];

  const svcRunning = services?.filter((s) => s.Status === "Running").length ?? 0;
  const svcStopped = services ? services.length - svcRunning : 0;
  const dbsOnline = databases?.filter((d) => d.status?.toLowerCase() === "online").length ?? 0;
  const dbsOffline = databases ? databases.length - dbsOnline : 0;
  const criticalDisks = disks?.filter((d) => d.UsedPercent >= 90).length ?? 0;
  const warningDisks = disks?.filter((d) => d.UsedPercent >= 80 && d.UsedPercent < 90).length ?? 0;
  const alertCount = alerts?.length ?? 0;

  return (
    <div className="space-y-4 animate-fade-in">
      {/* Hero Section */}
      <div className="rounded-3xl p-5 premium-gradient text-white">
        <div className="flex items-start justify-between gap-4">
          <div>
            <h2 className="text-xl font-black">سلامت عملیاتی</h2>
            <p className="text-sm mt-1 opacity-80">خلاصه وضعیت سرور؛ برای عملیات دقیق از تب تخصصی استفاده کنید</p>
          </div>
          <Button variant="secondary" size="sm">
            <RefreshCw className="w-4 h-4" />
            به‌روزرسانی
          </Button>
        </div>

        <div className="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5">
          <StatusBadgeCard
            icon={Cpu}
            label="سیستم"
            value={sysLoading ? "..." : `${Math.round(worst)}% مصرف`}
            sub={sysLoading ? "" : `CPU ${cpuPercent.toFixed(0)}% | RAM ${ramPercent.toFixed(0)}%`}
            level={worst >= 85 ? "danger" : worst >= 70 ? "warning" : "success"}
          />
          <StatusBadgeCard
            icon={HardDrive}
            label="دیسک"
            value={diskLoading ? "..." : criticalDisks ? `${criticalDisks} بحرانی` : warningDisks ? `${warningDisks} هشدار` : "پایدار"}
            sub={diskLoading ? "" : `${disks?.length || 0} درایو`}
            level={criticalDisks ? "danger" : warningDisks ? "warning" : "success"}
          />
          <StatusBadgeCard
            icon={Wrench}
            label="سرویس‌ها"
            value={svcLoading ? "..." : svcStopped ? `${svcStopped} نیاز بررسی` : "پایدار"}
            sub={svcLoading ? "" : `${services?.length || 0} سرویس`}
            level={svcStopped ? "warning" : "success"}
          />
          <StatusBadgeCard
            icon={Database}
            label="SQL / HA"
            value={dbLoading ? "..." : dbsOffline ? `${dbsOffline} نیاز بررسی` : "پایدار"}
            sub={dbLoading ? "" : `${databases?.length || 0} دیتابیس`}
            level={dbsOffline ? "warning" : "success"}
          />
        </div>
      </div>

      {/* Charts Row */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <Card>
          <CardContent>
            <div className="flex items-center justify-between mb-3">
              <h3 className="font-bold text-textMain flex items-center gap-2">
                <Activity className="w-4 h-4 text-primary" />
                CPU & RAM
              </h3>
              {system && (
                <span className="text-xs text-textMuted">
                  {formatUptime(system.uptimeSeconds)} آپتایم
                </span>
              )}
            </div>
            <UsageAreaChart data={chartData} />
          </CardContent>
        </Card>

        <Card>
          <CardContent>
            <div className="flex items-center justify-between mb-3">
              <h3 className="font-bold text-textMain flex items-center gap-2">
                <Bell className="w-4 h-4 text-primary" />
                هشدارهای فعال
              </h3>
              <Badge variant={alertCount > 0 ? "danger" : "success"}>
                {alertCount > 0 ? `${alertCount} هشدار` : "همه پایدار"}
              </Badge>
            </div>
            <div className="space-y-2">
              {alerts && alerts.length > 0 ? (
                alerts.slice(0, 5).map((a) => (
                  <div
                    key={a.id}
                    className="flex items-start gap-3 rounded-2xl border border-border/60 bg-cardSoft/50 px-3.5 py-2.5 text-sm"
                  >
                    <AlertTriangle className={`w-4 h-4 mt-0.5 shrink-0 ${a.severity === "critical" ? "text-danger" : "text-warning"}`} />
                    <div className="min-w-0 flex-1">
                      <div className="font-bold text-textMain truncate">{a.title}</div>
                      <div className="text-textMuted text-xs truncate">{a.message}</div>
                    </div>
                    <span className="text-[10px] text-textMuted shrink-0">{formatRelativeTime(a.timestamp)}</span>
                  </div>
                ))
              ) : (
                <div className="flex flex-col items-center py-8 text-textMuted">
                  <CheckCircle className="w-10 h-10 text-success mb-2" />
                  <span className="font-bold text-sm">همه چیز پایدار است</span>
                  <span className="text-xs">هشدار فعالی برای این سرور وجود ندارد</span>
                </div>
              )}
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Stats Row */}
      <div className="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <MiniStatCard icon={Server} label="سرورها" value="1" />
        <MiniStatCard icon={Wrench} label="سرویس‌ها" value={services?.length ?? "..."} />
        <MiniStatCard icon={Database} label="دیتابیس‌ها" value={databases?.length ?? "..."} />
        <MiniStatCard icon={Bell} label="هشدارها" value={alertCount} />
      </div>

      {/* Disk Overview Mini */}
      {disks && disks.length > 0 && (
        <Card>
          <CardContent>
            <h3 className="font-bold text-textMain mb-3 flex items-center gap-2">
              <HardDrive className="w-4 h-4 text-primary" />
              وضعیت دیسک‌ها
            </h3>
            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
              {disks.map((d) => (
                <div key={d.Drive} className="rounded-2xl border border-border/60 bg-cardSoft/50 p-3">
                  <div className="flex items-center justify-between mb-2">
                    <span className="font-bold text-sm text-textMain">{d.Drive}</span>
                    <Badge variant={d.UsedPercent >= 90 ? "danger" : d.UsedPercent >= 80 ? "warning" : "success"}>
                      {formatPercent(d.UsedPercent)}
                    </Badge>
                  </div>
                  <div className="h-2 rounded-full bg-border/60 overflow-hidden">
                    <div
                      className={`h-full rounded-full transition-all duration-500 ${d.UsedPercent >= 90 ? "bg-danger" : d.UsedPercent >= 80 ? "bg-warning" : "bg-success"}`}
                      style={{ width: `${Math.min(d.UsedPercent, 100)}%` }}
                    />
                  </div>
                  <div className="flex justify-between mt-1.5 text-[11px] text-textMuted">
                    <span>{d.UsedGB} GB مصرف</span>
                    <span>{d.TotalGB} GB کل</span>
                  </div>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      )}
    </div>
  );
}

function StatusBadgeCard({
  icon: Icon, label, value, sub, level
}: {
  icon: typeof Cpu;
  label: string;
  value: string;
  sub: string;
  level: "success" | "warning" | "danger";
}) {
  const colors = { success: "bg-success/10 text-success", warning: "bg-warning/10 text-warning", danger: "bg-danger/10 text-danger" };
  return (
    <div className="rounded-2xl bg-white/10 backdrop-blur-sm p-3.5">
      <div className="flex items-center gap-2 mb-2">
        <div className={`w-8 h-8 rounded-xl ${colors[level]} flex items-center justify-center`}>
          <Icon className="w-4 h-4" />
        </div>
        <span className="text-xs opacity-80 font-medium">{label}</span>
      </div>
      <div className="text-sm font-black">{value}</div>
      <div className="text-[10px] opacity-70 mt-0.5">{sub}</div>
    </div>
  );
}

function MiniStatCard({ icon: Icon, label, value }: { icon: typeof Server; label: string; value: string | number }) {
  return (
    <div className="rounded-2xl border border-border/80 bg-card p-3.5 flex items-center gap-3">
      <div className="w-9 h-9 rounded-xl bg-primaryLight flex items-center justify-center text-primary shrink-0">
        <Icon className="w-4.5 h-4.5" />
      </div>
      <div>
        <div className="text-xs text-textMuted font-medium">{label}</div>
        <div className="font-black text-textMain">{value}</div>
      </div>
    </div>
  );
}
