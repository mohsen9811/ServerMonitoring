                  <td className="px-4 py-2.5 text-textMuted">{h.duration}ms</td>
                  <td className="px-4 py-2.5 text-textMuted text-xs">{formatDate(h.timestamp)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </Card>
    </div>
  );
}
