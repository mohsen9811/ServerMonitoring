                      {iisEnabled && <Globe className="w-3 h-3 text-primary" />}
                      {creditEnabled && <CreditCard className="w-3 h-3 text-warning" />}
                    </div>
                  </div>
                </button>
              </div>
            );
          })
        )}
      </div>
    </>
  );
}
