import { useState, useEffect } from "react";
import { AnimatePresence, motion } from "framer-motion";
import {
  Gauge, Cpu, HardDrive, Wrench, Globe, Clock, Database, Network,
  CreditCard, FolderTree, Bell, SlidersHorizontal, Server
} from "lucide-react";
import { useServerStore } from "../../stores/serverStore";
import { useAlertStore } from "../../stores/alertStore";
import { useAlerts } from "../../hooks/useQueries";
import { ThemeToggle } from "../ui/ThemeToggle";
import { Sidebar } from "./Sidebar";
import { DashboardTab } from "../tabs/DashboardTab";
import { SystemTab } from "../tabs/SystemTab";
import { DiskTab } from "../tabs/DiskTab";
import { ServicesTab } from "../tabs/ServicesTab";
import { IisTab } from "../tabs/IisTab";
import { JobsTab } from "../tabs/JobsTab";
import { DatabasesTab } from "../tabs/DatabasesTab";
import { ConnectivityTab } from "../tabs/ConnectivityTab";
import { CreditTab } from "../tabs/CreditTab";
import { FilesTab } from "../tabs/FilesTab";
import { AlertsTab } from "../tabs/AlertsTab";
import { SettingsTab } from "../tabs/SettingsTab";

interface TabDef {
  id: string;
  label: string;
  icon: typeof Server;
  permission?: "sql" | "iis" | "credit";
}

const ALL_TABS: TabDef[] = [
  { id: "dashboard", label: "داشبورد", icon: Gauge },
  { id: "system", label: "سیستم", icon: Cpu },
  { id: "disk", label: "دیسک", icon: HardDrive },
  { id: "services", label: "سرویس‌ها", icon: Wrench },
  { id: "iis", label: "IIS", icon: Globe, permission: "iis" },
  { id: "jobs", label: "Jobs", icon: Clock, permission: "sql" },
  { id: "databases", label: "Database/HA", icon: Database, permission: "sql" },
  { id: "connectivity", label: "Linked", icon: Network, permission: "sql" },
  { id: "credit", label: "اعتباری", icon: CreditCard, permission: "credit" },
  { id: "files", label: "فایل‌ها", icon: FolderTree },
  { id: "alerts", label: "هشدارها", icon: Bell },
  { id: "settings", label: "تنظیمات", icon: SlidersHorizontal },
];

export function DashboardLayout() {
  const { servers, currentServerId, sidebarCollapsed, setSidebarCollapsed } = useServerStore();
  const { setAlerts } = useAlertStore();
  const [activeTab, setActiveTab] = useState("dashboard");

  const currentServer = servers.find((s) => s.id === currentServerId);
  const hasSql = currentServer?.features?.sql ?? currentServer?.sql?.enabled ?? true;
  const hasIis = currentServer?.features?.iis ?? currentServer?.iis?.enabled ?? false;
  const hasCredit = currentServer?.features?.credit ?? currentServer?.credit?.enabled ?? false;

  // Fetch alerts when server changes
  const { data: alertsData } = useAlerts(currentServerId ?? undefined);
  useEffect(() => {
    if (alertsData) setAlerts(alertsData as any);
  }, [alertsData]);

  const visibleTabs = ALL_TABS.filter((t) => {
    if (!t.permission) return true;
    if (t.permission === "sql") return hasSql;
    if (t.permission === "iis") return hasIis;
    if (t.permission === "credit") return hasCredit;
    return true;
  });

  useEffect(() => {
    if (!visibleTabs.some((t) => t.id === activeTab)) setActiveTab("dashboard");
  }, [currentServerId, hasSql, hasIis, hasCredit]);

  const renderTab = () => {
    const props = { serverId: currentServerId };
    switch (activeTab) {
      case "dashboard": return <DashboardTab {...props} />;
      case "system": return <SystemTab {...props} />;
      case "disk": return <DiskTab {...props} />;
      case "services": return <ServicesTab {...props} />;
      case "iis": return <IisTab {...props} />;
      case "jobs": return <JobsTab {...props} />;
      case "databases": return <DatabasesTab {...props} />;
      case "connectivity": return <ConnectivityTab {...props} />;
      case "credit": return <CreditTab {...props} />;
      case "files": return <FilesTab {...props} />;
      case "alerts": return <AlertsTab {...props} />;
      case "settings": return <SettingsTab {...props} />;
      default: return <DashboardTab {...props} />;
    }
  };

  return (
    <div dir="rtl" className="h-screen flex gap-3 p-3 bg-background text-textMain overflow-hidden">
      {/* Sidebar */}
      <motion.aside
        animate={{ width: sidebarCollapsed ? 72 : 260 }}
        className="h-full rounded-3xl border border-border/80 glass-card flex flex-col overflow-hidden shrink-0"
      >
        <Sidebar collapsed={sidebarCollapsed} onToggle={() => setSidebarCollapsed(!sidebarCollapsed)} />
      </motion.aside>

      {/* Main */}
      <main className="flex-1 min-w-0 h-full rounded-3xl border border-border/80 glass-card flex flex-col overflow-hidden">
        {/* Header */}
        <header className="flex items-center justify-between px-5 py-3 border-b border-border/60 shrink-0">
          <div className="flex items-center gap-3 min-w-0">
            <div className="w-10 h-10 rounded-2xl bg-primaryLight flex items-center justify-center text-primary shrink-0">
              <Server className="w-5 h-5" />
            </div>
            <div className="min-w-0">
              <div className="text-xs font-medium text-textMuted">سرور فعال</div>
              <h1 className="text-base font-extrabold text-textMain truncate">
                {currentServer?.name || "انتخاب سرور"}
              </h1>
              {currentServer && (
                <div className="text-[11px] text-textMuted font-mono" dir="ltr">
                  {currentServer.host}
                </div>
              )}
            </div>
          </div>
          <div className="flex items-center gap-2">
            <ThemeToggle />
          </div>
        </header>

        {/* Tab Bar */}
        <nav className="flex items-center gap-1 px-3 py-2 border-b border-border/60 overflow-x-auto scrollbar-none shrink-0" role="tablist" aria-label="بخش‌های مانیتورینگ">
          {visibleTabs.map((tab) => {
            const Icon = tab.icon;
            const isActive = activeTab === tab.id;
            return (
              <button
                key={tab.id}
                role="tab"
                aria-selected={isActive}
                onClick={() => setActiveTab(tab.id)}
                className={cn(
                  "flex items-center gap-2 px-3.5 h-9 rounded-xl text-xs font-bold whitespace-nowrap shrink-0 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/30",
                  isActive
                    ? "premium-gradient text-white shadow-glow"
                    : "text-textMuted hover:text-textMain hover:bg-primaryLight/50"
                )}
              >
                <Icon className="w-4 h-4" />
                <span className="hidden sm:inline">{tab.label}</span>
              </button>
            );
          })}
        </nav>

        {/* Content */}
        <div className="flex-1 min-h-0 overflow-auto p-4 scrollbar-thin">
          <AnimatePresence mode="wait">
            <motion.div
              key={activeTab}
              initial={{ opacity: 0, y: 4 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -4 }}
              transition={{ duration: 0.15 }}
            >
              {currentServerId ? (
                renderTab()
              ) : (
                <div className="flex items-center justify-center h-full text-center py-32">
                  <div>
                    <Server className="w-16 h-16 mx-auto mb-4 text-textMuted/40" />
                    <h2 className="text-xl font-bold text-textMain mb-2">یک سرور را انتخاب کنید</h2>
                    <p className="text-textMuted text-sm max-w-md">
                      از منوی سمت راست یک سرور را انتخاب کنید تا مانیتورینگ سیستم، سرویس‌ها، دیتابیس و سایر بخش‌ها نمایش داده شود.
                    </p>
                  </div>
                </div>
              )}
            </motion.div>
          </AnimatePresence>
        </div>
      </main>
    </div>
  );
}

function cn(...classes: (string | boolean | undefined | null)[]): string {
  return classes.filter(Boolean).join(" ");
}
