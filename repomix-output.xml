      {/* Servers List */}
      <div className="flex-1 overflow-auto px-3 py-3 space-y-1 scrollbar-none">
        {filteredServers.length === 0 ? (
          <div className="text-center text-textMuted text-xs py-8">
            {localSearch ? "سروری یافت نشد" : "هنوز سروری اضافه نشده"}
          </div>
        ) : (
          filteredServers.map((server) => {
            const isActive = currentServerId === server.id;
            const sqlEnabled = server.features?.sql ?? server.sql?.enabled ?? true;
            const iisEnabled = server.features?.iis ?? server.iis?.enabled ?? false;
            const creditEnabled = server.features?.credit ?? server.credit?.enabled ?? false;

            return (
              <div key={server.id} className={cn("relative group", sortMode ? "pr-8" : "")}>
