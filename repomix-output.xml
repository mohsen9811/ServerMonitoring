                    <button onClick={() => handleReorder(server.id, "down")} className="flex items-center justify-center w-5 h-4 rounded text-textMuted hover:text-primary hover:bg-primaryLight text-[10px]" aria-label="انتقال به پایین">
                      <ChevronDown className="w-3 h-3" />
