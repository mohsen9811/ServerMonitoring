# ServerPulse Monitor - Environment Configuration
# Copy this file to .env and customize

# Server Port
PORT=3000

# Environment
NODE_ENV=development

# Comma-separated browser origins allowed to call the API in production.
# Empty means same-origin/development access is accepted.
CORS_ORIGINS=http://localhost:3000

# API protection and collection tuning
API_RATE_LIMIT=600
MONITOR_CONCURRENCY=4
MONITOR_CACHE_SYSTEM_MS=3000
MONITOR_CACHE_DISK_MS=10000
MONITOR_CACHE_DATABASES_MS=15000
MONITOR_CACHE_ALERTS_MS=10000

# In-memory history capacity (1440 samples ~= 2 hours at a 5-second interval)
METRICS_HISTORY_LIMIT=1440

# Optional: Custom config directory (defaults to backend/config)
# CONFIG_DIR=./backend/config
